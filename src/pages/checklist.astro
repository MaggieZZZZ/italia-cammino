---
import Layout from "../layouts/Layout.astro";
import PrepNav from "../components/PrepNav.astro";

// 按 2026-07-17 状态倒推，出发 2026-09-26
const bookings = [
  { when: "✅ 已约 · 2026-07-22", urgency: "done", item: "意大利申根签递交", url: "/visa", note: "深圳 / 上海 / 成都三地；四人各带一套独立材料和预约确认单" },
  { when: "⚠️ 已约 · 2026-10-03 11:30", urgency: "critical", item: "Cenacolo 最后的晚餐", url: "https://cenacolovinciano.org", note: "预约早于第 4 人加入：立即核对订单是否已有 4 席；当天 Firenze → Milano → Venezia" },
  { when: "立即", urgency: "now", item: "护照、领区与签证材料", url: "/visa", note: "护照、户口/居住证明、近 3 月流水、在职证明、营业执照先准备" },
  { when: "立即", urgency: "now", item: "全程住宿订定", url: "", note: "4 座住宿城市共 10 晚：Roma 4 / Firenze 3 / Venezia 2 / Milano 1" },
  { when: "立即", urgency: "now", item: "申根旅行医疗保险", url: "", note: "签证材料：覆盖申根及往返日期，医疗不少于 €30,000，含紧急医疗遣返" },
  { when: "立即查看余票", urgency: "now", item: "Uffizi 美术馆 Firenze", url: "https://www.uffizi.it/en/tickets", note: "目标 9/30 下午；2026 官方预售票为实名票" },
  { when: "2026-07-27 前后", urgency: "soon", item: "梵蒂冈博物馆", url: "https://www.museivaticani.va", note: "目标 9/28 早场；只从官方票务入口购买" },
  { when: "2026-08-02 前后", urgency: "soon", item: "Accademia Firenze (David)", url: "https://www.galleriaaccademiafirenze.it/en/tickets/", note: "目标 10/1 下午；开放后立即选时段" },
  { when: "2026-08-27 (30 天前)", urgency: "schedule", item: "Colosseo + Foro + Palatino", url: "https://parcocolosseo.it", note: "联票 €18，9/27 早 09:00" },
  { when: "2026-08-27 (30 天前)", urgency: "schedule", item: "Duomo Milano (含屋顶)", url: "https://www.duomomilano.it", note: "10/5 下午，目标 15:30 后" },
  { when: "2026-09-01 (25 天前)", urgency: "schedule", item: "Duomo Firenze Cupola", url: "https://duomo.firenze.it", note: "10/1 早 08:30 登顶" },
  { when: "2026-09-05 (3 周前)", urgency: "schedule", item: "庞贝古城", url: "https://pompeiisites.org", note: "9/29 早场" },
  { when: "7–8 月", urgency: "soon", item: "高铁全程", url: "https://www.trenitalia.com/en.html", note: "Napoli 往返 + Roma–Firenze；10/3 Firenze–Milano–Venezia；10/5 Venezia–Milano" },
  { when: "2026-09-10 (2 周前)", urgency: "schedule", item: "Basilica San Marco", url: "https://www.basilicasanmarco.it", note: "改到 10/4 早场" },
  { when: "2026-09-10 (2 周前)", urgency: "schedule", item: "Palazzo Ducale Venezia", url: "https://palazzoducale.visitmuve.it", note: "10/4 上午，接在 San Marco 后" },
  { when: "2026-09-10 (2 周前)", urgency: "schedule", item: "Peggy Guggenheim", url: "https://www.guggenheim-venice.it", note: "10/5 上午可选，之后乘中午高铁去 Milano" },
  { when: "2026-09-12 (2 周前)", urgency: "schedule", item: "餐厅订位", url: "", note: "Roscioli / Da Enzo / Antiche Carampane / Osteria alle Testiere / Trattoria Sostanza" },
  { when: "2026-09-25 (出发前一天)", urgency: "final", item: "所有票电子版核对 + 打印", url: "", note: "存手机 + 云端 + 纸质各一份" },
];
---

<Layout title="行程准备中心 · 意大利">
  <PrepNav />

  <div class="checklist-page">
    <header class="page-header">
      <p class="eyebrow">TRIP CONTROL CENTER</p>
      <h1>行程准备中心</h1>
      <p class="subtitle">2026-09-26 罗马会合 · 2026-10-06 米兰离境 · 4 人组（香港 2 / 上海 1 / 成都 1）</p>
    </header>

    <section class="module-grid">
      <a href="/itinerary">
        <span>01</span>
        <b>逐日行程</b>
        <p>4—3—2—1 北上路线、每天怎么玩、吃什么、怎么移动。</p>
        <em>11 天 · 10 晚 →</em>
      </a>
      <a href="/visa">
        <span>02</span>
        <b>申根签证</b>
        <p>深圳、上海、成都三地递签，四套材料与各领区表格。</p>
        <em>现在优先处理 →</em>
      </a>
      <a href="#bookings">
        <span>03</span>
        <b>门票与交通</b>
        <p>按开放窗口排列的预约任务，只走官方购票入口。</p>
        <em>看时间表 ↓</em>
      </a>
      <a href="#departure">
        <span>04</span>
        <b>出发准备</b>
        <p>行李、App、安全、四人协作和票据备份。</p>
        <em>看出发清单 ↓</em>
      </a>
    </section>

    <section>
      <h2>📋 现在就做</h2>
      <ul class="task-list">
        <li><b>申根签证</b>：7 月 22 日分别在深圳、上海、成都递交；现在逐项备齐四套独立材料；<a href="/visa">打开签证专页 →</a></li>
        <li><b>最后的晚餐</b>：已约 10 月 3 日 11:30；<b>立即核对订单是否覆盖新加入成员，共 4 席</b></li>
        <li><b>护照</b>：至少 2 页空白页；官方最低离开申根后有效 3 个月，建议按 6 个月留余量</li>
        <li><b>旅行保险</b>：签证要求医疗不少于 €30,000，覆盖申根区、完整往返日期、紧急医疗与遣返</li>
        <li><b>机酒一致</b>：四家住宿覆盖 10 晚，四位姓名与护照拼写一致；国际航班按香港 / 上海 / 成都三组分别附单</li>
        <li><b>所有共同预订</b>：酒店、意大利高铁、博物馆和餐厅统一检查数量是否为 4</li>
        <li><b>签证行程单</b>：先以<a href="/itinerary">逐日行程</a>为骨架，酒店和火车确定后生成英文递签版</li>
        <li><b>国际驾照</b>：仅 backup（这次不开车不需要）</li>
        <li><b>通知信用卡公司</b>：境外消费提醒，避免被冻结。建议带 2 张不同发卡行（Visa + Mastercard）</li>
        <li><b>欧元现金</b>：每人备 €300-500 应急（小店 / Trastevere 餐厅可能只收现金）</li>
        <li><b>手机方案</b>：意大利 eSIM（如 Holafly / Airalo，€20-40/人 10 天）或 TIM 实体卡</li>
      </ul>
    </section>

    <section id="bookings">
      <h2>🗓 订票时间表</h2>
      <p class="hint">按这个顺序订。<b>红色 = 必抢</b>，其他按日期到了再办。</p>
      <div class="booking-table">
        <div class="row header-row">
          <div class="cell when">何时</div>
          <div class="cell item">项目</div>
          <div class="cell note">备注</div>
        </div>
        {bookings.map(b => (
          <div class:list={["row", b.urgency]}>
            <div class="cell when">{b.when}</div>
            <div class="cell item">
              {b.url ? <a href={b.url} target="_blank" rel="noopener">{b.item} ↗</a> : b.item}
            </div>
            <div class="cell note">{b.note}</div>
          </div>
        ))}
      </div>
    </section>

    <section id="departure">
      <h2>🎒 行李清单</h2>
      <div class="two-col">
        <div>
          <h3>必带</h3>
          <ul class="task-list">
            <li>护照（+ 复印件 + 云端 PDF）</li>
            <li>欧元现金 + 信用卡 × 2</li>
            <li>充电宝（≤100Wh，10000mAh 安全）</li>
            <li>欧标转换插头（Type L / Type F）</li>
            <li>耳机 + 各种线</li>
            <li>常用药 + 处方药</li>
            <li>太阳镜 + 防晒霜</li>
          </ul>
        </div>
        <div>
          <h3>9 月意大利穿衣</h3>
          <ul class="task-list">
            <li>白天 22-27°C，早晚 15-18°C</li>
            <li>薄外套 / 风衣（早晚 + 室内空调）</li>
            <li><b>一双好走的鞋</b>（罗马 / Firenze 全是石板路）</li>
            <li>教堂着装：肩膀 + 膝盖必须遮（梵蒂冈安检会查）</li>
            <li>3 件衬衫 / T 恤 + 1 件白衬衫（晚餐）</li>
            <li>薄围巾（教堂遮肩 + 防冷气）</li>
            <li>折叠雨伞（9 月偶有阵雨）</li>
          </ul>
        </div>
      </div>
    </section>

    <section>
      <h2>📱 必装 App</h2>
      <ul class="task-list">
        <li><b>Google Maps</b>：提前下载意大利离线地图</li>
        <li><b>Google Translate</b>：下载意大利语离线包 + 拍照翻译菜单</li>
        <li><b>Trenitalia</b> 官方 app：火车票 + 实时班次</li>
        <li><b>Uber / FreeNow</b>：意大利打车（FreeNow 比 Uber 覆盖好）</li>
        <li><b>WhatsApp</b>：意大利餐厅 / 民宿房东都用</li>
        <li><b>携程 / 飞猪</b>：备查机票订单</li>
        <li><b>本网站</b>：把 italia-cammino.pages.dev 加桌面快捷方式</li>
      </ul>
    </section>

    <section>
      <h2>🚨 安全 + 紧急</h2>
      <ul class="task-list">
        <li><b>紧急电话</b>：112（欧盟通用，警 + 急救 + 消防）</li>
        <li><b>中国驻意大利使馆领事保护</b>：+39 06 9669 5200（24h）</li>
        <li><b>护照丢失</b>：先报警拿 verbale di denuncia，再去中国驻罗马 / 米兰使馆补</li>
        <li><b>小偷高发区</b>：Roma Termini / Napoli 火车站 / 威尼斯圣马可 / 米兰中央站。钱包分开放</li>
        <li><b>ATM 优选银行内</b>：街头 ATM 可能被装假读卡器</li>
        <li><b>餐厅信用卡</b>：要求 POS 机送过来，不让卡离开视线</li>
        <li><b>出租车</b>：只坐白色 + Comune di Roma/Milano 标志的，机场 fix-rate 必问</li>
      </ul>
    </section>

    <section>
      <h2>👯 四人协作</h2>
      <ul class="task-list">
        <li><b>分工建议</b>：A 负责博物馆票 / B 负责高铁 / C 负责餐厅 / D 负责住宿与订单人数复核</li>
        <li><b>罗马会合</b>：上海、成都航班确认后，写清最晚抵达时间、酒店地址与机场到市区方案</li>
        <li><b>共享文档</b>：开个 Google Drive 文件夹，所有 PDF 票放进去</li>
        <li><b>微信群</b>：发预订确认邮件截图存档</li>
        <li><b>失散预案</b>：约 Roma Termini 中央大厅 Feltrinelli 书店门口集合（明显 + 24h 开放）</li>
        <li><b>每天早上 10 分钟</b>：确认当天行程 + 现金分配 + 谁带哪张票</li>
      </ul>
    </section>

    <section>
      <h2>🍝 文化小贴士</h2>
      <ul class="task-list">
        <li>意大利人午饭 13:00-15:00，晚饭 20:00-23:00。早到餐厅没人，被当游客</li>
        <li>咖啡：早上才喝 cappuccino，11 点后只喝 espresso（点 cappuccino 会被笑）</li>
        <li>意大利人不放鸡肉到意面里。点 carbonara 不要要求加鸡</li>
        <li>"Aperitivo" 时段 18:00-20:00：点一杯酒 €8-12 会送大盘小食，等于变相晚饭</li>
        <li>意大利餐厅一般加 €2-3 的 coperto（餐位费），不是小费</li>
        <li>小费：满意服务舍入到最近 €5（不要求 15-20%）</li>
        <li>商店周日下午 + 周一上午多数关门</li>
        <li>教堂里安静、关闪光灯</li>
      </ul>
    </section>

    <div class="meta">
      <p>清单和行程都会随讨论更新。看到要改的点 → 右下角 💬 哔哔赖赖。</p>
    </div>
  </div>
</Layout>

<style>
  .checklist-page { max-width: 980px; margin: 0 auto; padding: 40px 24px 80px; }
  .page-header { margin-bottom: 28px; }
  .eyebrow { color: var(--era-renaissance); font-size: 10px; letter-spacing: 1.7px; margin: 0 0 8px; }
  h1 { font-family: var(--font-serif-zh); font-size: clamp(32px, 5vw, 48px); margin: 0 0 6px; }
  .subtitle { color: var(--text-muted); font-size: 13px; margin: 0; }

  section { margin-top: 36px; }
  h2 { font-family: var(--font-serif-zh); font-size: 18px; margin: 0 0 14px; color: var(--text); }
  h3 { font-family: var(--font-serif-zh); font-size: 15px; margin: 0 0 8px; color: var(--text); }
  .hint { color: var(--text-muted); font-size: 12px; margin: -4px 0 12px; }

  .task-list { color: var(--text-secondary); font-size: 14px; line-height: 1.85; padding-left: 20px; margin: 0; }
  .task-list li { margin-bottom: 6px; }
  .task-list b { color: var(--text); }
  .task-list a { color: var(--era-renaissance); }

  .module-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 0; }
  .module-grid > a { display: flex; flex-direction: column; min-height: 190px; padding: 17px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; }
  .module-grid > a:hover { border-color: var(--era-renaissance); }
  .module-grid span { color: var(--text-muted); font-size: 10px; letter-spacing: 1px; }
  .module-grid b { font-family: var(--font-serif-zh); font-size: 17px; margin: 13px 0 7px; }
  .module-grid p { color: var(--text-muted); font-size: 11.5px; line-height: 1.65; margin: 0; }
  .module-grid em { color: var(--era-renaissance); font-size: 11px; font-style: normal; margin-top: auto; padding-top: 14px; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }

  .booking-table { display: flex; flex-direction: column; gap: 4px; }
  .row { display: grid; grid-template-columns: 240px 1fr 1.5fr; gap: 12px; padding: 10px 14px; background: var(--bg-card); border-radius: 6px; font-size: 13px; }
  .row.header-row { background: transparent; padding: 4px 14px; color: var(--text-muted); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; }
  .row.critical { background: color-mix(in srgb, var(--era-ancient-rome) 18%, var(--bg-card)); border-left: 3px solid var(--era-ancient-rome); }
  .row.done { background: color-mix(in srgb, var(--era-renaissance) 10%, var(--bg-card)); border-left: 3px solid var(--era-renaissance); }
  .row.now { border-left: 3px solid var(--era-renaissance); }
  .row.soon { border-left: 3px solid var(--era-medieval); }
  .row.schedule { border-left: 3px solid var(--border-strong); }
  .row.final { border-left: 3px solid var(--era-baroque); }
  .cell { line-height: 1.55; }
  .cell.when { color: var(--text); font-weight: 500; }
  .cell.item a { color: var(--era-renaissance); text-decoration: none; }
  .cell.item a:hover { text-decoration: underline; }
  .cell.note { color: var(--text-muted); }
  @media (max-width: 768px) {
    .checklist-page { padding: 30px 16px 80px; }
    .module-grid { grid-template-columns: repeat(2, 1fr); }
    .row { grid-template-columns: 1fr; gap: 4px; padding: 12px 14px; }
    .row.header-row { display: none; }
    .cell.when { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
    .cell.item { font-size: 14px; }
  }
  @media (max-width: 480px) {
    .module-grid { grid-template-columns: 1fr; }
    .module-grid > a { min-height: 150px; }
  }

  .meta { margin-top: 60px; padding-top: 20px; border-top: 1px solid var(--border); }
  .meta p { color: var(--text-muted); font-size: 12px; }
</style>
