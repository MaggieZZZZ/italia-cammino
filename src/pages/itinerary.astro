---
import Layout from "../layouts/Layout.astro";
import PrepNav from "../components/PrepNav.astro";

const route = [
  { city: "Roma", zh: "罗马", nights: 4, dates: "9/26—9/30", href: "/city/roma", note: "古罗马 · 梵蒂冈 · 庞贝一日游" },
  { city: "Firenze", zh: "佛罗伦萨", nights: 3, dates: "9/30—10/3", href: "/city/firenze", note: "文艺复兴 · 美术馆 · 左岸慢走" },
  { city: "Venezia", zh: "威尼斯", nights: 2, dates: "10/3—10/5", href: "/city/venezia", note: "圣马可 · 大运河 · 潟湖离岛" },
  { city: "Milano", zh: "米兰", nights: 1, dates: "10/5—10/6", href: "/city/milano", note: "大教堂 · Galleria · 离境" },
];

const fixedAnchors = [
  { date: "07/22", title: "深圳 VFS 递签", note: "已预约 · 三人各自一套材料" },
  { date: "10/03 · 11:30", title: "Cenacolo · 最后的晚餐", note: "已预约 · 当天借道 Milano 前往 Venezia" },
];

const days = [
  {
    day: "01", date: "9/26 · 周六", city: "Roma", tag: "抵达 · 放慢",
    plan: ["08:05 抵达 Fiumicino", "寄存行李 + 午睡恢复", "Trastevere 漫步", "Gianicolo 日落"],
    food: "晚餐放在 Trastevere；第一天不安排预约型景点。",
  },
  {
    day: "02", date: "9/27 · 周日", city: "Roma", tag: "古罗马轴",
    plan: ["Colosseo 第一时段", "Foro Romano + Palatino", "Pantheon", "Navona → Trevi → Spanish Steps"],
    food: "午餐 Roscioli / 晚餐 Armando al Pantheon；都需要提前订位。",
  },
  {
    day: "03", date: "9/28 · 周一", city: "Roma", tag: "梵蒂冈",
    plan: ["Vatican Museums 早场", "Sistine Chapel", "St. Peter’s Basilica", "Castel Sant’Angelo 河岸"],
    food: "午餐 Pizzarium Bonci；教堂要求遮肩、遮膝。",
  },
  {
    day: "04", date: "9/29 · 周二", city: "Napoli + Pompei", tag: "一日往返",
    plan: ["Roma → Napoli 高铁", "Pompei 约 4 小时", "MANN 考古博物馆", "披萨后返回 Roma"],
    food: "Da Michele 吃 Margherita；这天强度最高，火车要留换乘余量。",
  },
  {
    day: "05", date: "9/30 · 周三", city: "Roma → Firenze", tag: "移动 · Uffizi",
    plan: ["上午高铁到 Firenze SMN", "寄存行李", "Uffizi 下午场", "Ponte Vecchio 黄昏"],
    food: "午餐 Trattoria Mario / 晚餐 Trattoria Sostanza。",
  },
  {
    day: "06", date: "10/1 · 周四", city: "Firenze", tag: "圆顶 · 大卫",
    plan: ["Duomo Cupola 早场", "洗礼堂 + 主教座堂", "Mercato Centrale", "Accademia 看 David"],
    food: "傍晚走 Oltrarno；晚餐 Il Santo Bevitore。",
  },
  {
    day: "07", date: "10/2 · 周五", city: "Firenze", tag: "宫殿 · 日落",
    plan: ["Pitti Palace", "Boboli Gardens", "Oltrarno 手工作坊", "Piazzale Michelangelo 日落"],
    food: "午餐 Gusta Pizza / 晚餐 Buca dell’Orafo；留半天不赶路。",
  },
  {
    day: "08", date: "10/3 · 周六", city: "Firenze → Milano → Venezia", tag: "Cenacolo · 11:30",
    plan: ["早班高铁到 Milano", "11:00 前抵达取票 / 核验", "11:30 看《最后的晚餐》", "下午高铁到 Venezia"],
    food: "午餐放在 Santa Maria delle Grazie 周边；威尼斯入住后走 Rialto cicchetti 小食路线。",
  },
  {
    day: "09", date: "10/4 · 周日", city: "Venezia", tag: "圣马可 · 潟湖",
    plan: ["Basilica San Marco 早场", "Palazzo Ducale", "Murano + Burano", "返回主岛看夜色"],
    food: "Burano 午餐 Gatto Nero；若不去离岛，就改为 Dorsoduro + Peggy Guggenheim。",
  },
  {
    day: "10", date: "10/5 · 周一", city: "Venezia → Milano", tag: "现代艺术 · 哥特",
    plan: ["早上 Peggy（可选）", "中午高铁到 Milano", "Duomo 屋顶", "Galleria + Navigli"],
    food: "Navigli aperitivo；晚餐 Trattoria Arlati。",
  },
  {
    day: "11", date: "10/6 · 周二", city: "Milano → Hong Kong", tag: "离境",
    plan: ["退房 + 最终核票", "约 09:00 前往 Malpensa", "最迟 09:45—10:00 抵达机场", "12:45 直飞香港"],
    food: "前一晚完成打包；再次确认机场是 MXP 而不是 LIN。",
  },
];

const transfers = [
  ["9/29", "Roma Termini → Napoli Centrale → Roma", "Frecciarossa 往返"],
  ["9/30", "Roma Termini → Firenze S. M. Novella", "约 1h30"],
  ["10/3", "Firenze S. M. Novella → Milano Centrale", "选能在 10:15 前抵达的早班"],
  ["10/3", "Milano Centrale → Venezia S. Lucia", "Cenacolo 后的下午班次"],
  ["10/5", "Venezia S. Lucia → Milano Centrale", "约 2h25"],
  ["10/6", "Milano Centrale / Cadorna → Malpensa MXP", "约 50min"],
];
---

<Layout title="逐日行程 · 意大利行程准备" description="2026 年 9 月 26 日至 10 月 6 日意大利逐日路线">
  <PrepNav />

  <main class="itinerary-page">
    <header class="hero">
      <p class="eyebrow">10 NIGHTS · 3 PEOPLE · ROMA IN / MILANO OUT</p>
      <h1>4—3—2—1，路线锁定</h1>
      <p>9/26 08:05 落地罗马，10/6 12:45 从米兰回香港。10/3 为了 11:30 的《最后的晚餐》，从 Firenze 先到 Milano，再继续去 Venezia 住两晚。</p>
      <div class="hero-actions">
        <a href="#daily">看逐日安排 ↓</a>
        <button type="button" id="print-itinerary">打印 / 存 PDF</button>
      </div>
    </header>

    <section class="fixed-anchors" aria-label="已确认的固定预约">
      {fixedAnchors.map(anchor => (
        <div>
          <time>{anchor.date}</time>
          <p><b>{anchor.title}</b><span>{anchor.note}</span></p>
          <em>CONFIRMED</em>
        </div>
      ))}
    </section>

    <section class="route-grid" aria-label="住宿城市路线">
      {route.map((stop, index) => (
        <a href={stop.href} class="route-card">
          <span class="route-index">{String(index + 1).padStart(2, "0")}</span>
          <div>
            <b>{stop.zh} <i>{stop.city}</i></b>
            <strong>{stop.nights} 晚</strong>
            <small>{stop.dates} · {stop.note}</small>
          </div>
        </a>
      ))}
    </section>

    <section class="principles">
      <div>
        <span>第一原则</span>
        <b>每座城市只抓一条主轴</b>
        <p>罗马看帝国与教廷，佛罗伦萨看文艺复兴，威尼斯看海上共和国，米兰收尾达·芬奇与现代城市。</p>
      </div>
      <div>
        <span>体力安排</span>
        <b>重日后接半日移动</b>
        <p>庞贝是最累的一天；佛罗伦萨第三天与威尼斯清晨刻意留白，不把每小时塞满。</p>
      </div>
      <div>
        <span>签证一致性</span>
        <b>四城 10 晚不能漏</b>
        <p>10/3 虽经过 Milano，但当晚住 Venezia；酒店、英文行程单和火车必须写清楚，Napoli 同样只是一日游。</p>
      </div>
    </section>

    <section id="daily">
      <div class="section-head">
        <div>
          <p class="eyebrow">DAY BY DAY</p>
          <h2>逐日安排</h2>
        </div>
        <p>这是一版可执行骨架；预约成功后，以票面时段为锚点微调。</p>
      </div>
      <div class="days">
        {days.map(day => (
          <article class="day-card">
            <div class="day-no">DAY <b>{day.day}</b></div>
            <div class="day-main">
              <header>
                <div>
                  <span>{day.date}</span>
                  <h3>{day.city}</h3>
                </div>
                <em>{day.tag}</em>
              </header>
              <ol>
                {day.plan.map((item, index) => <li><span>{index + 1}</span>{item}</li>)}
              </ol>
              <p>{day.food}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="transport">
      <div class="section-head">
        <div>
          <p class="eyebrow">TRANSFERS</p>
          <h2>需要落单的交通</h2>
        </div>
        <a href="https://www.trenitalia.com/en.html" target="_blank" rel="noopener">Trenitalia 官网 ↗</a>
      </div>
      <div class="transport-list">
        {transfers.map(row => (
          <div>
            <time>{row[0]}</time>
            <b>{row[1]}</b>
            <span>{row[2]}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="visa-bridge">
      <div>
        <p class="eyebrow">FOR THE VISA</p>
        <h2>下一步：做英文签证版</h2>
        <p>当前网站记录的是旅行体验版。等四家酒店名称和城际班次确定后，再生成一页英文简表，递签时与机酒订单放在一起。</p>
      </div>
      <a href="/visa#documents">查看签证材料清单 →</a>
    </section>
  </main>
</Layout>

<script>
  document.querySelector("#print-itinerary")?.addEventListener("click", () => window.print());
</script>

<style>
  .itinerary-page { max-width: 1040px; margin: 0 auto; padding: 46px 24px 90px; }
  .eyebrow { color: var(--era-renaissance); font-size: 10px; letter-spacing: 1.8px; text-transform: uppercase; margin: 0 0 8px; }
  .hero { max-width: 790px; padding: 12px 0 38px; }
  h1 { font-family: var(--font-serif-zh); font-size: clamp(38px, 6vw, 66px); line-height: 1.1; margin: 0 0 14px; }
  .hero > p:not(.eyebrow) { color: var(--text-secondary); font-size: 15px; line-height: 1.8; margin: 0; }
  .hero-actions { display: flex; gap: 9px; margin-top: 20px; }
  .hero-actions a, .hero-actions button { padding: 9px 14px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-secondary); font-size: 12px; }
  .hero-actions a { color: var(--text); border-color: var(--era-renaissance); }

  .fixed-anchors { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-top: 0; }
  .fixed-anchors > div { display: grid; grid-template-columns: 80px 1fr auto; gap: 14px; align-items: center; padding: 14px 16px; background: color-mix(in srgb, var(--era-renaissance) 9%, var(--bg-card)); border: 1px solid var(--border); border-left: 3px solid var(--era-renaissance); border-radius: 7px; }
  .fixed-anchors time { color: var(--era-renaissance); font-size: 12px; font-weight: 600; }
  .fixed-anchors p { margin: 0; }
  .fixed-anchors b { display: block; font-size: 12px; }
  .fixed-anchors span { display: block; color: var(--text-muted); font-size: 10px; margin-top: 2px; }
  .fixed-anchors em { color: var(--text-muted); font-size: 8px; font-style: normal; letter-spacing: 1px; }
  .route-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 16px; }
  .route-card { display: grid; grid-template-columns: 28px 1fr; gap: 9px; min-height: 150px; padding: 16px; background: var(--bg-card); border: 1px solid var(--border); border-top: 3px solid var(--era-renaissance); border-radius: 8px; }
  .route-card:hover { border-color: var(--era-renaissance); }
  .route-index { color: var(--text-muted); font-size: 10px; letter-spacing: 1px; }
  .route-card b { display: block; font-family: var(--font-serif-zh); font-size: 16px; }
  .route-card i { color: var(--text-muted); font: 400 11px/1 var(--font-sans); }
  .route-card strong { display: block; color: var(--era-renaissance); font-size: 22px; margin: 12px 0 6px; }
  .route-card small { display: block; color: var(--text-muted); font-size: 11px; line-height: 1.55; }

  .principles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 8px 0 58px; }
  .principles > div { padding: 16px; border: 1px solid var(--border); border-radius: 7px; }
  .principles span { color: var(--text-muted); font-size: 10px; letter-spacing: 1px; }
  .principles b { display: block; font-size: 13px; margin: 5px 0; }
  .principles p { color: var(--text-muted); font-size: 11px; line-height: 1.65; margin: 0; }

  section { margin-top: 52px; }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 24px; margin-bottom: 16px; }
  h2 { font-family: var(--font-serif-zh); font-size: 23px; margin: 0; }
  .section-head > p, .section-head > a { color: var(--text-muted); font-size: 12px; margin: 0; }
  .section-head > a { color: var(--era-renaissance); }
  .days { display: flex; flex-direction: column; gap: 8px; }
  .day-card { display: grid; grid-template-columns: 90px 1fr; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .day-no { padding: 18px; color: var(--text-muted); font-size: 9px; letter-spacing: 1.2px; border-right: 1px solid var(--border); }
  .day-no b { display: block; color: var(--text); font: 500 27px/1 var(--font-sans); margin-top: 4px; }
  .day-main { padding: 17px 20px; }
  .day-main header { display: flex; justify-content: space-between; gap: 20px; align-items: flex-start; }
  .day-main header span { color: var(--text-muted); font-size: 11px; }
  .day-main h3 { font-family: var(--font-serif-zh); font-size: 18px; margin: 2px 0 0; }
  .day-main em { color: var(--era-renaissance); font-size: 10px; font-style: normal; letter-spacing: .7px; padding: 5px 8px; border: 1px solid color-mix(in srgb, var(--era-renaissance) 45%, transparent); border-radius: 999px; white-space: nowrap; }
  .day-main ol { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; padding: 0; margin: 14px 0 10px; list-style: none; }
  .day-main li { color: var(--text-secondary); font-size: 11px; line-height: 1.5; padding: 9px; background: var(--bg-card-elevated); border-radius: 5px; }
  .day-main li span { display: block; color: var(--text-muted); font-size: 9px; margin-bottom: 4px; }
  .day-main > p { color: var(--text-muted); font-size: 11px; margin: 0; }

  .transport-list { border-top: 1px solid var(--border); }
  .transport-list > div { display: grid; grid-template-columns: 70px 1fr 120px; gap: 18px; padding: 13px 4px; border-bottom: 1px solid var(--border); font-size: 12px; }
  .transport-list time, .transport-list span { color: var(--text-muted); }
  .transport-list b { color: var(--text-secondary); font-weight: 500; }
  .visa-bridge { display: flex; align-items: end; justify-content: space-between; gap: 28px; padding: 24px; background: color-mix(in srgb, var(--era-renaissance) 8%, var(--bg-card)); border: 1px solid var(--border); border-radius: 9px; }
  .visa-bridge p:not(.eyebrow) { max-width: 660px; color: var(--text-secondary); font-size: 12px; line-height: 1.7; margin: 8px 0 0; }
  .visa-bridge > a { color: var(--era-renaissance); font-size: 12px; white-space: nowrap; }

  @media (max-width: 820px) {
    .fixed-anchors { grid-template-columns: 1fr; }
    .route-grid { grid-template-columns: repeat(2, 1fr); }
    .principles { grid-template-columns: 1fr; }
    .day-main ol { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .itinerary-page { padding: 30px 14px 80px; }
    .route-grid { grid-template-columns: 1fr; }
    .fixed-anchors > div { grid-template-columns: 72px 1fr; }
    .fixed-anchors em { display: none; }
    .route-card { min-height: auto; }
    .section-head, .visa-bridge { align-items: flex-start; flex-direction: column; }
    .day-card { grid-template-columns: 62px 1fr; }
    .day-no { padding: 14px 10px; }
    .day-main { padding: 14px; }
    .day-main ol { grid-template-columns: 1fr; }
    .transport-list > div { grid-template-columns: 54px 1fr; gap: 6px 12px; }
    .transport-list span { grid-column: 2; }
  }

  @media print {
    :global(.top-nav), :global(.prep-nav), :global(.trivia-card), :global(.report-button), .hero-actions { display: none !important; }
    :global(body) { background: #fff; color: #111; }
    .itinerary-page { max-width: none; padding: 0; }
    .route-card, .day-card, .principles > div, .visa-bridge { background: #fff; border-color: #bbb; break-inside: avoid; }
    .day-main li { background: #f2f2f2; color: #222; }
    .day-card { margin-bottom: 6px; }
  }
</style>
