---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { eraColor, type EraId } from "../lib/eraColors";

const eras = (await getCollection("eras")).sort((a, b) => a.data.order - b.data.order);
const cities = await getCollection("cities");

function citiesForEra(eraId: string) {
  return cities.filter(c => (c.data.era_weights[eraId as EraId] ?? 0) > 0)
    .sort((a, b) => (b.data.era_weights[eraId as EraId] ?? 0) - (a.data.era_weights[eraId as EraId] ?? 0));
}
---

<Layout title="时代轴 · 意大利">
  <nav class="breadcrumb">
    <a href="/">← 地图</a>
    <span>/</span>
    <b>时代轴</b>
  </nav>

  <div class="timeline-page">
    <header class="page-header">
      <h1>意大利历史时代轴</h1>
      <p>每个时代下，看哪些城市在当时最活跃</p>
    </header>

    <div class="eras-grid">
      {eras.map(era => {
        const activeCities = citiesForEra(era.data.id);
        const color = eraColor(era.data.id as EraId);
        return (
          <div class="era-col" style={{ "--era-color": color }}>
            <div class="era-header">
              <div class="era-dot"></div>
              <div>
                <div class="era-name">{era.data.name_zh}</div>
                <div class="era-range">{era.data.range}</div>
              </div>
            </div>
            <div class="era-cities">
              {activeCities.map(c => (
                <a href={`/city/${c.data.slug}`} class="era-city">
                  {c.data.name_zh}
                  <span class="weight">{c.data.era_weights[era.data.id as EraId]}</span>
                </a>
              ))}
              {activeCities.length === 0 && <span class="empty">暂无内容</span>}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>

<style>
  .breadcrumb { padding: 12px 24px; border-bottom: 1px solid var(--border); background: #1a1a1a; font-size: 13px; color: var(--text-muted); display: flex; gap: 8px; }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb b { color: var(--text); }
  .timeline-page { padding: 32px; }
  .page-header { margin-bottom: 32px; }
  .page-header h1 { font-family: var(--font-serif-zh); font-size: 24px; margin: 0 0 6px; }
  .page-header p { color: var(--text-muted); font-size: 13px; margin: 0; }
  .eras-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
  .era-col { background: var(--bg-card); border-radius: 10px; padding: 16px; border-top: 3px solid var(--era-color); }
  .era-header { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; }
  .era-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--era-color); margin-top: 3px; flex-shrink: 0; }
  .era-name { color: var(--text); font-size: 13px; font-weight: 600; }
  .era-range { color: var(--text-muted); font-size: 10px; margin-top: 2px; }
  .era-cities { display: flex; flex-direction: column; gap: 6px; }
  .era-city { display: flex; justify-content: space-between; align-items: center; padding: 6px 10px; background: #1a1f25; border-radius: 5px; font-size: 12px; color: var(--text-secondary); }
  .era-city:hover { color: var(--text); background: #2a3340; }
  .weight { color: var(--era-color); font-size: 10px; font-weight: 600; }
  .empty { color: var(--text-faint); font-size: 11px; }
</style>
